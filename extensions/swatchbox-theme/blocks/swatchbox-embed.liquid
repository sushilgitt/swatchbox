{% comment %}
  Swatchbox app embed block.
  Renders globally (target: body). On product pages it injects the swatch config
  + variant data as JSON and loads the storefront script, which replaces the
  native variant picker with swatches. No theme code edits required.
{% endcomment %}

{% if block.settings.enabled %}
  {%- if product or collection or search -%}
    {{ 'swatchbox.css' | asset_url | stylesheet_tag }}

    {%- if product -%}
      {% render 'swatchbox-config', shape: block.settings.shape, size: block.settings.size, show_price: block.settings.show_price %}
    {%- elsif collection or search -%}
      {% render 'swatchbox-collection', shape: block.settings.shape, size: block.settings.size %}
    {%- endif -%}

    <script src="{{ 'swatchbox.js' | asset_url }}" defer></script>
  {%- endif -%}
{% endif %}

{% schema %}
{
  "name": "Swatchbox",
  "target": "body",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Enable Swatchbox on product pages",
      "default": true
    },
    {
      "type": "select",
      "id": "shape",
      "label": "Swatch shape",
      "options": [
        { "value": "circle", "label": "Circle" },
        { "value": "square", "label": "Square" },
        { "value": "rounded", "label": "Rounded square" }
      ],
      "default": "circle"
    },
    {
      "type": "range",
      "id": "size",
      "label": "Swatch size",
      "min": 24,
      "max": 56,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show price difference on swatches",
      "default": false
    }
  ]
}
{% endschema %}
